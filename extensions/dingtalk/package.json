{
  "name": "@openclaw/dingtalk",
  "version": "2026.2.27",
  "private": true,
  "description": "OpenClaw DingTalk bot Stream/Webhook channel plugin",
  "type": "module",
  "peerDependencies": {
    "openclaw": ">=2026.1.26"
  },
  "openclaw": {
    "extensions": [
      "./index.ts"
    ],
    "channel": {
      "id": "dingtalk",
